# ====== FinQuery RAG 环境变量配置 ======
# 部署在云服务器 (2核2G) 上，通过 FRP 穿透访问学校 GPU 服务器

# ====== 在线对话：指向 FRP 映射回来的本地 8500 端口 (学校算力) ======
# FRP 将云服务器的 127.0.0.1:8500 映射到学校 GPU 服务器的 8998 端口
LLM_API_BASE_URL=http://127.0.0.1:8500/v1
LLM_API_KEY=not-needed-for-local
LLM_MODEL_NAME=nanochat

# ====== 离线数据清洗：NVIDIA 开放平台配置 ======
# 用于 PDF 表格语义增强 (process_tables.py)
# 获取 API Key: https://build.nvidia.com/meta/llama-3_1-8b-instruct
NVIDIA_API_KEY=nvapi-your-real-nvidia-key-here
NVIDIA_MODEL_NAME=meta/llama-3.1-8b-instruct

# ====== 数据库配置 ======
# PostgreSQL (生产环境) 或 SQLite (开发环境)
DATABASE_URL=sqlite:///./temp.db

# ====== 安全配置 ======
# JWT 密钥 (生产环境请更换为随机强密钥)
SECRET_KEY=9594873a5e0a8ccde1adc3af1ba93f5f2bcc5632b77b750452713d216791c013

# ====== 跨域配置 ======
# 允许的前端来源，多个用逗号分隔
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ====== 向量数据库路径 ======
CHROMA_PATH=./chroma_db
