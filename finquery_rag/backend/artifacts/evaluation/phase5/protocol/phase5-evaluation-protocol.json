    "recall_at_5",
    "precision_at_5",
    "mrr",
    "ndcg_at_5",
    "document_coverage",
    "expected_page_recall"
  ],
  "slices": {
    "intent": ["document_qa", "financial_calculation", "document_summary", "multi_document_comparison", "front_matter", "conversation", "unknown"],
    "language": ["chinese", "english", "mixed"],
    "source_type": ["narrative_paragraph", "table", "front_matter", "multi_page", "multi_document"],
    "difficulty": ["direct", "paraphrased", "multi_hop", "ambiguous", "adversarial_no_answer"],
    "safety": ["expected_answer", "expected_no_answer", "calculation_blocked", "unsupported_numeric_trap", "wrong_period_trap", "wrong_unit_trap", "wrong_citation_trap"]
  },
  "calibration_search_space": {
    "n_results": [3, 5, 7, 10],
    "min_score_threshold": [0.0, 0.1, 0.2, 0.3],
    "numeric_rrf_floor": [0.0, 0.05, 0.1],
    "numeric_dense_floor": [0.0, 0.1, 0.2],
    "max_context_tokens": [2048, 4096, 6144],
    "sufficiency_best_score_threshold": [0.3, 0.4, 0.5],
    "sufficiency_average_score_threshold": [0.2, 0.3, 0.4],
    "document_coverage_threshold": [0.0, 0.5, 1.0]
  },
  "candidate_selection_rule": {
    "steps": [
      "eliminate candidates with any safety metric worse than baseline",
      "eliminate candidates with new unsupported_numeric_release",
      "eliminate candidates with new calculation_mismatch_release",
      "eliminate candidates with invalid_citation_release higher than baseline",
      "maximize macro_strict_pass_rate among remaining",
      "tiebreak: higher citation_recall",
      "tiebreak: lower p95_latency",
      "tiebreak: smallest diff from baseline"
    ]
  },
  "ablation_variants": [
    {"id": "A0", "name": "Full System", "config_diff": {}},
    {"id": "A1", "name": "Dense Only", "config_diff": {"disable_bm25": true}},
    {"id": "A2", "name": "BM25 Only", "config_diff": {"disable-dense": true}},
    {"id": "A3", "name": "No Reranker", "config_diff": {"disable-reranker": true}},
    {"id": "A4", "name": "No Query Rewrite", "config_diff": {"disable-query-rewrite": true}},
    {"id": "A5", "name": "No Hierarchical Context", "config_diff": {"disable-hierarchical-context": true}},
    {"id": "A6", "name": "No Calculator", "config_diff": {"disable-calculation-pipeline": true}},
    {"id": "A7", "name": "No Answerability Gate", "config_diff": {"disable-answerability": true}},
    {"id": "A8", "name": "No Post-generation Validation", "config_diff": {"disable-validation-pipeline": true}},
    {"id": "A9", "name": "No Citation Validation", "config_diff": {"disable-citation-validation": true}}
