    "unsafe_answer_rate",
    "validator_fail_closed_rate"
  ],
  "utility_metrics": [
    "strict_case_pass_rate",
    "macro_strict_pass_rate",
    "supported_answer_coverage",
    "correct_refusal_rate",
    "answered_case_rate"
  ],
  "retrieval_metrics": [
