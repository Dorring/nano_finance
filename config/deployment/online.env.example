# Phase 7 Rootless Online Serving Configuration
# Copy to online.env and adjust values. Do NOT commit online.env.

# --- Model Service ---
MODEL_HOST=127.0.0.1
MODEL_PORT=18001
MODEL_NAME=finquery-finance-sft1147
MODEL_SOURCE=sft
MODEL_TAG=d24_final_mixdata
MODEL_STEP=1147
MODEL_TEMPERATURE=0
MODEL_MAX_TOKENS=512
CUDA_VISIBLE_DEVICES=0

# --- Backend Service ---
BACKEND_HOST=127.0.0.1
BACKEND_PORT=18002
BACKEND_WORKERS=1
BACKEND_RELOAD=false

# LLM connection (points to model service)
LLM_API_BASE_URL=http://127.0.0.1:18001/v1
LLM_API_KEY=not-needed-for-local
LLM_MODEL_NAME=finquery-finance-sft1147

# Database
DATABASE_URL=sqlite:///./runtime/phase7/finquery.db

# RAG storage
CHROMA_PATH=./finquery_rag/backend/chroma_db
BM25_DB_PATH=./finquery_rag/backend/rag_bm25.db
DOCUMENT_REGISTRY_DB_PATH=./finquery_rag/backend/document_registry.db
SESSIONS_DB_PATH=./finquery_rag/backend/sessions.db
TRACE_DB_PATH=./finquery_rag/backend/trace_log.db

# Security
SECRET_KEY=change-me-to-a-random-secret

# CORS
ALLOWED_ORIGINS=http://127.0.0.1:18003,http://localhost:18003

# --- Frontend Service ---
FRONTEND_HOST=127.0.0.1
FRONTEND_PORT=18003
# Frontend calls backend via this URL
VITE_API_URL=http://127.0.0.1:18002

# --- Conda/Venv paths (adjust to your environment) ---
CONDA_ENV_NAME=nano
BACKEND_VENV_PATH=

# --- tmux session names ---
TMUX_SESSION_MODEL=nano-finance-model
TMUX_SESSION_BACKEND=nano-finance-backend
TMUX_SESSION_FRONTEND=nano-finance-frontend
